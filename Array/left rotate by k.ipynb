   "source": [
    "def leftrotateb_by_k(k):\n",
    "    arr=[1,2,3,4,5,6,7]\n",
    "    temp=arr[0:3]\n",
    "    for i in range (k,len(arr)):\n",
    "        arr[i-k]=arr[i]\n",
    "    for j in range (len(arr)-k,len(arr)):\n",
    "        arr[j]=temp[j+k-len(arr)]\n",
    "    return arr\n",
    "leftrotateb_by_k(3)\n",
    "\n"
   ]
  }
 ],
