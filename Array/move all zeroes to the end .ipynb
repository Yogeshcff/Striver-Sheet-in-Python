   "source": [
    "def movezero():\n",
    "    arr=[1,2,0,3,5,0,0,7,0,5,9]\n",
    "    j=-1\n",
    "    for k in range (0,len(arr)):\n",
    "        if arr[k]==0:\n",
    "            j=k\n",
    "            break\n",
    "    for i in range (j,len(arr)):\n",
    "        if arr[i]!=0:\n",
    "            arr[i],arr[j]=arr[j],arr[i]\n",
    "            j=j+1\n",
    "    return arr\n",
    "movezero()"
   ]
  }
 ],
