   "source": [
    "arr=[1,2,4,7,7,5]\n",
    "largest = arr[0]\n",
    "sl = -1\n",
    "for i in range (1,len(arr)):\n",
    "    if arr[i] > largest:\n",
    "        sl = largest\n",
    "        largest = arr[i]\n",
    "    elif arr[i] < largest and arr[i]>sl:\n",
    "        sl = arr[i]\n",
    "print(sl)"
   ]
  }
