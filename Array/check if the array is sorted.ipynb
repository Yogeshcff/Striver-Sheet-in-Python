    "    arr=[1,0,3,4,5]\n",
    "    for i in range (1,len(arr)):\n",
    "        if arr[i]>arr[i-1]:\n",
    "            continue\n",
    "        else:\n",
    "            return False\n",
    "    return True\n",
    "checksorted()\n"
